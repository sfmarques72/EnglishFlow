# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# JWT_SECRET: Secret used to sign auth session cookies / tokens.
# Generate a long random string for production (required on Vercel).
JWT_SECRET="change-me-to-a-long-random-secret"

# PORT: HTTP port for the Express server (default 3000).
PORT=3000

# APP_URL: Public URL of the app (optional).
APP_URL="MY_APP_URL"
